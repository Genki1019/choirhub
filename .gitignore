# ===========================
# Node / package managers
# ===========================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ===========================
# Build outputs
# ===========================
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ===========================
# Testing
# ===========================
coverage/
test-results/

# ===========================
# Environment & secrets
# ===========================
.env*
!.env.example

# ===========================
# OS / Editor
# ===========================
.DS_Store
*.pem
.vercel
.claude/

# ===========================
# Debug logs
# ===========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===========================
# 画像・音声・バイナリメディア
# SVG はテキスト形式のため対象外
# ===========================
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.pdf
*.mp3
*.wav
*.mid
*.midi

# ドキュメント用スクリーンショットは追跡対象
!docs/images/*.png
!docs/images/*.jpg

# ===========================
# デモファイル（大容量・git 管理外）
# ※ 画像/音声ルールと重複するが意図を明示
# ===========================
apps/web/public/demo/

# ===========================
# API アップロードファイル（開発用ローカルストレージ）
# 本番は Cloudflare R2 を使用
# ===========================
apps/api/uploads/**
!apps/api/uploads/**/.gitkeep

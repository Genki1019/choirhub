# ── データベース ──────────────────────────────────────────────────────
# Pooled connection（アプリ用）
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# Direct connection（マイグレーション用）
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── サーバー ──────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://your-web.vercel.app

# ── メール（Resend） ──────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=ChoirHub <noreply@your-domain.com>
# 開発用: 実際の送信先を上書きするアドレス（本番では設定不要）
# DEV_MAIL_TO=dev@example.com

# ── Upstash Redis（レートリミット） ───────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Cloudflare R2 ファイルストレージ ──────────────────────────────────
# 未設定時はローカルの ./uploads/ を使用（開発用）
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=choirhub-files
# アバター公開用 CDN URL（R2 カスタムドメインまたは pub-xxx.r2.dev）
R2_PUBLIC_URL=https://files.your-domain.com

# ── API プロキシ（サーバーサイド） ────────────────────────────────────
# Next.js サーバーから API へのリライト先（内部 URL）
API_INTERNAL_URL=https://your-api.vercel.app

# ── API クライアント（ブラウザ） ──────────────────────────────────────
# クライアントサイドの fetch で使用するベース URL
# Vercel のリライト経由にする場合は空文字でよい（デフォルト）
NEXT_PUBLIC_API_URL=

# ── Cloudflare R2 ─────────────────────────────────────────────────────
# 設定するとビルド時に /uploads/* リライトを省略する
R2_BUCKET_NAME=choirhub-files

# ── Google Maps API（任意） ───────────────────────────────────────────
# イベント会場住所の Places Autocomplete に使用
# GOOGLE_MAPS_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

{
  "name": "choirhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @choirhub/web dev",
    "dev:api": "pnpm --filter @choirhub/api dev",
    "dev": "pnpm run dev:web & pnpm run dev:api",
    "build": "pnpm --filter @choirhub/web build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,json,md}": "prettier --write"
  }
}
